{
  "meta": {
    "name": "default-dark",
    "version": "1.0.0",
    "type": "cli"
  },
  "ansi": {
    "reset": "\u001b[0m",
    "bold": "\u001b[1m",
    "dim": "\u001b[2m",
    "underline": "\u001b[4m",
    "colors": {
      "black": "\u001b[30m",
      "red": "\u001b[31m",
      "green": "\u001b[32m",
      "yellow": "\u001b[33m",
      "blue": "\u001b[34m",
      "magenta": "\u001b[35m",
      "cyan": "\u001b[36m",
      "white": "\u001b[37m"
    }
  },
  "levels": {
    "debug": {
      "color": "cyan",
      "label": "DEBUG",
      "priority": 10
    },
    "info": {
      "color": "green",
      "label": "INFO",
      "priority": 20
    },
    "warn": {
      "color": "yellow",
      "label": "WARN",
      "priority": 30
    },
    "error": {
      "color": "red",
      "label": "ERROR",
      "priority": 40
    },
    "critical": {
      "color": "magenta",
      "label": "CRITICAL",
      "bold": true,
      "priority": 50
    }
  },
  "format": {
    "timestamp": true,
    "timestampFormat": "ISO",
    "showLevel": true,
    "showCode": true,
    "maxMessageLength": 500
  }
}